/target
/dist
**/*.rs.bk
.DS_Store

# Local Claude Code settings (not shared).
/.claude/

# animate.py outputs + basemap tile cache (generated locally).
/anim/
/scripts/.tilecache/

# Raw source CSVs are large and re-downloadable; the preprocessor's
# compact outputs under static/data/ are committed instead.
/data-src/

# Hourly per-station-year files are large (~250 MB across 1986–2024). They are
# generated by preprocess.py and served statically (rsynced on deploy), but not
# committed. The committed daily tier (series-daily/) + map-stats power the app
# without them; the Hour interval loads them on demand.
/static/data/series/
